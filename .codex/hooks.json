{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".agent-hooks/pre_tool_guard.sh codex PreToolUse",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".agent-hooks/verify_pipeline.sh codex Stop",
            "timeout": 60
          }
        ]
      }
    ]
  }
}