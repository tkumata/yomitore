{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".agent-hooks/dispatcher.sh codex PreToolUse",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".agent-hooks/dispatcher.sh codex Stop",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
