{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": ".agent-hooks/pre_tool_guard.sh copilot preToolUse",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": ".agent-hooks/verify_pipeline.sh copilot agentStop",
        "timeoutSec": 60
      }
    ]
  }
}
